{
  "name": "opportunity-management",
  "description": "AWS Partner Central API Opportunity Management Sample",
  "version": "0.2.4",
  "private": true,
  "homepage": "https://aws-samples.github.io/partner-crm-integration-samples",
  "dependencies": {
    "@aws-sdk/client-partnercentral-selling": "^3.821.0",
    "@cloudscape-design/components": "^3.0.0",
    "@cloudscape-design/global-styles": "^1.0.0",
    "aws-sdk": "^2.1400.0",
    "axios": "^1.10.0",
    "js-yaml": "^4.1.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.14.0",
    "react-scripts": "^5.0.1"
  },
  "scripts": {
    "start": "react-scripts start",
    "build": "GENERATE_SOURCEMAP=false react-scripts build",
    "build:harmony": "GENERATE_SOURCEMAP=false PUBLIC_URL=/opportunity-management react-scripts build",
    "build:github": "GENERATE_SOURCEMAP=false PUBLIC_URL=https://aws-samples.github.io/partner-crm-integration-samples react-scripts build",
    "build-harmony-app": "node scripts/build-harmony.js",
    "restore-package": "node scripts/restore-package.js",
    "test": "react-scripts test",
    "eject": "react-scripts eject",
    "predeploy": "npm run build:github",
    "postdeploy": "npm run restore-package",
    "deploy": "gh-pages -d build"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ],
    "rules": {
      "no-unused-vars": "warn",
      "jsx-a11y/anchor-is-valid": "warn"
    }
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "overrides": {
    "uglify-js": "^3.17.4",
    "postcss": "^8.4.31",
    "webpack-dev-server": "^4.15.2",
    "nth-check": "^2.1.1"
  },
  "displayName": "Partner Central API",
  "bindleId": "amzn1.bindle.resource.wywxxqwcubux7smhqf5q",
  "harmony": {
    "appName": "opportunity-management",
    "headers": [
      {
        "name": "Content-Security-Policy",
        "value": "connect-src 'self' https://partnercentral-selling.us-east-1.api.aws https://partnercentral-selling-beta.us-east-1.api.aws/ https://partnercentral-selling-pre-prod.us-east-1.api.aws/ https://partnercentral-selling-gamma.us-east-1.api.aws https://partnercentral-selling-alpha.us-east-1.api.aws https://*.us-east-1.elb.amazonaws.com https://*.us-west-2.amazon.com http://localhost:8080 midway-auth.amazon.com;"
      }
    ]
  }
}